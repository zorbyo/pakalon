{
	"name": "@pakalon/tanstack-adapter",
	"version": "0.1.0",
	"description": "Tanstack AI SDK ChatClient adapter that delegates to oh-my-pi's multi-provider LLM engine",
	"homepage": "https://pakalon.dev",
	"author": "Pakalon Team",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pakalon/pakalon-cli.git",
		"directory": "packages/tanstack-adapter"
	},
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./chat": {
			"types": "./src/chat.ts",
			"import": "./src/chat.ts"
		},
		"./models": {
			"types": "./src/models.ts",
			"import": "./src/models.ts"
		}
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@oh-my-pi/pi-ai": "workspace:*",
		"@oh-my-pi/pi-utils": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md"
	]
}
