{
	"type": "module",
	"name": "@pakalon/sessions",
	"version": "0.1.0",
	"description": "Multi-session management for Pakalon",
	"license": "MIT",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"test": "bun test --parallel"
	},
	"dependencies": {
		"@oh-my-pi/pi-utils": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
}
