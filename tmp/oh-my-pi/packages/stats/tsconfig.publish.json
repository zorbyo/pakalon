{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"emitDeclarationOnly": true,
		"declaration": true,
		"declarationMap": false,
		"sourceMap": false,
		"inlineSources": false,
		"rootDir": "src",
		"outDir": "dist/types",
		"noCheck": true
	},
	"include": [
		"src"
	],
	"exclude": [
		"src/client",
		"dist",
		"node_modules",
		"test",
		"tests",
		"scripts"
	]
}
