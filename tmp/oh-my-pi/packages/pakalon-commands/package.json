{
	"type": "module",
	"name": "@pakalon/commands",
	"version": "0.1.0",
	"description": "Slash command registry for /init, /pakalon, /models, /plan, /build, etc.",
	"license": "MIT",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test --parallel",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@oh-my-pi/pi-utils": "catalog:",
		"@pakalon/phases": "workspace:*",
		"@pakalon/modes": "workspace:*",
		"@pakalon/memory": "workspace:*",
		"@pakalon/sessions": "workspace:*",
		"@pakalon/auth": "workspace:*",
		"@pakalon/agent-teams": "workspace:*",
		"@pakalon/auditor": "workspace:*",
		"@pakalon/penpot": "workspace:*",
		"@pakalon/automations": "workspace:*",
		"@pakalon/telegram": "workspace:*",
		"@pakalon/billing": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
}
