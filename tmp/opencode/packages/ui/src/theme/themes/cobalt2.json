{
  "$schema": "https://opencode.ai/desktop-theme.json",
  "name": "Cobalt2",
  "id": "cobalt2",
  "light": {
    "palette": {
      "neutral": "#ffffff",
      "ink": "#193549",
      "primary": "#0066cc",
      "accent": "#00acc1",
      "success": "#4caf50",
      "warning": "#ff9800",
      "error": "#e91e63",
      "info": "#ff5722"
    },
    "overrides": {
      "text-weak": "#5c6b7d",
      "syntax-comment": "#5c6b7d",
