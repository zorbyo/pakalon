{
  "$schema": "https://opencode.ai/desktop-theme.json",
  "name": "Vesper",
  "id": "vesper",
  "light": {
    "palette": {
      "neutral": "#F0F0F0",
      "ink": "#101010",
      "primary": "#FFC799",
      "accent": "#B30000",
      "success": "#99FFE4",
      "warning": "#FFC799",
      "error": "#FF8080",
      "info": "#FFC799",
      "diffAdd": "#99FFE4",
      "diffDelete": "#FF8080"
    },
    "overrides": {
      "syntax-comment": "#7a7a7a",
      "syntax-keyword": "#6e6e6e",
      "syntax-string": "#117e69",
      "syntax-primitive": "#8d541c",
