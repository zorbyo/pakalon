  "dark": {
    "palette": {
      "neutral": "#101010",
      "ink": "#FFF",
      "primary": "#FFC799",
      "accent": "#FF8080",
      "success": "#99FFE4",
      "warning": "#FFC799",
      "error": "#FF8080",
      "info": "#FFC799",
      "diffAdd": "#99FFE4",
      "diffDelete": "#FF8080"
    },
    "overrides": {
      "syntax-comment": "#8b8b8b",
      "syntax-keyword": "#a0a0a0",
      "syntax-string": "#99ffe4",
