{
  "name": "pakalon",
  "version": "1.0.0",
  "description": "AI-powered CLI code editor with pure TypeScript runtime - builds production software in 6 autonomous phases",
  "keywords": [
    "ai",
    "cli",
    "code-editor",
    "agentic",
    "pakalon",
    "openrouter",
    "typescript",
    "copilot-cli"
  ],
  "license": "MIT",
  "bin": {
    "pakalon": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "bun scripts/build.js all",
    "build:cli": "bun scripts/build.js cli",
    "build:legacy-cli": "bun scripts/build.js legacy-cli",
    "build:app": "bun scripts/build.js app",
    "dev": "bun src/index.tsx",
    "start": "bun run dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -p tsconfig.runtime.json --noEmit",
    "type-check:all": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepublishOnly": "bun run build && bun run type-check"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=25.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@modelcontextprotocol/sdk": "^1.6.0",
    "@octokit/rest": "^22.0.1",
    "@openrouter/ai-sdk-provider": "2.2.3",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/eventsource": "^1.1.15",
    "@types/figlet": "^1.7.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/react": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/yargs": "^17.0.33",
    "ai": "6.0.91",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.0",
    "cheerio": "^1.2.0",
    "chokidar": "^4.0.0",
    "chromadb": "^1.10.1",
    "cohere-ai": "^8.0.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.0",
    "eventsource": "^3.0.2",
    "fast-glob": "^3.3.2",
    "ffmpeg-static": "^5.3.0",
    "figlet": "^1.8.0",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.2.0",
    "ink": "6.8.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.5",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.1.0",
    "oh-my-logo": "^0.4.0",
    "ollama": "^0.6.3",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "os": "^0.1.2",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.52.0",
    "react": "^19.0.0",
    "react-devtools-core": "^7.0.1",
    "sharp": "^0.33.5",
    "simple-git": "^3.25.0",
    "term-img": "^6.0.0",
    "uuid": "^11.1.0",
    "web-tree-sitter": "^0.26.7",
    "yargs": "^17.7.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/coverage-v8": "^2.0.0",
    "axios": "^1.7.0",
    "bun-types": "^1.1.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.20.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
