# ============================================================
# Pakalon Backend — Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000","https://pakalon.com"]

# ── Deployment Mode ──────────────────────────────────────────
# Set to "selfhosted" for local deployments (Ollama / LM Studio).
# In selfhosted mode: cloud auth, billing, and schedulers are disabled.
# Only the /local/* endpoints are active.
PAKALON_MODE=cloud

# ── Self-Hosted Local Providers ──────────────────────────────
# URLs for Ollama and LM Studio (used when PAKALON_MODE=selfhosted)
PAKALON_OLLAMA_URL=http://localhost:11434
PAKALON_LMSTUDIO_URL=http://localhost:1234

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_PASSWORD=your-db-password
DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# ── Polar (Billing) ───────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_at_...
POLAR_WEBHOOK_SECRET=whsec_...
POLAR_PRODUCT_ID=prod_...

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@pakalon.com

# ── OpenRouter ────────────────────────────────────────────────
OPENROUTER_MASTER_KEY=sk-or-v1-...

# ── Security ──────────────────────────────────────────────────
# 32+ byte random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_generate_random_32_byte_hex

# ── APScheduler ───────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
