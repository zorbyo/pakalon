# ============================================================
# Pakalon Backend — Self-Hosted Environment Variables
# Copy this file to .env and adjust as needed.
# No cloud credentials required.
# ============================================================

# ── Application ──────────────────────────────────────────────
PAKALON_MODE=selfhosted
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Self-Hosted Local Providers ──────────────────────────────
# URLs for Ollama and LM Studio. Adjust if running on different ports.
PAKALON_OLLAMA_URL=http://localhost:11434
PAKALON_LMSTUDIO_URL=http://localhost:1234

# ── Security ──────────────────────────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-random-32-byte-hex-string
